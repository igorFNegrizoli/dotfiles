{
  "name": "claude-runner",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceMount": "source=${localEnv:HOME}/code/trustguard/v3-repos/,target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localEnv:HOME}/.config/claude-runner,target=/root/.config/claude-code,type=bind",
    "source=${localEnv:HOME}/.config/claude-runner/todo.txt,target=/root/todo.txt,type=bind",
    "source=${localEnv:HOME}/.config/claude-runner/skills,target=/root/skills,type=bind,readonly",
    "source=${localEnv:HOME}/.config/claude-runner/CLAUDE.md,target=/workspace/CLAUDE.md,type=bind",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
  ],
  "runArgs": [
      "--network=trustguard-v3-network",
      "--hostname=claude-runner"
    ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "customizations": {
    "claude-code": {
      "mcpServers": {
        "dev-browser": {
          "command": "npx",
          "args": ["-y", "@sawyerhood/dev-browser-mcp"]
        },
        "open-webSearch": {
          "command": "npx",
          "args": ["-y", "open-websearch-mcp"]
        }
      }
    }
  },

  "postCreateCommand": "npm install -g @anthropic-ai/claude-code 2>/dev/null || true"
}
