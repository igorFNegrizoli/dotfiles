{
  "name": "claude-runner",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "initializeommand": "mkdir -p ~/.config/claude-runner/skills && cp -rn ~/.config/claude/skills/. ~/.config/claude-runner/skills/",
  "workspaceMount": "source=${localEnv:HOME}/code/trustguard/v3-repos/,target=/workspace/v3-repos,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localEnv:HOME}/.config/claude-runner,target=/root/.claude,type=bind",
    "source=${localEnv:HOME}/.config/claude-runner/CLAUDE.md,target=/workspace/CLAUDE.md,type=bind",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
  ],
  "runArgs": [
      "--network=trustguard-v3-network",
      "--hostname=claude-runner"
    ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "customizations": {
    "claude-code": {
      "mcpServers": {
        "dev-browser": {
          "command": "npx",
          "args": ["-y", "@sawyerhood/dev-browser-mcp"]
        },
        "open-webSearch": {
          "command": "npx",
          "args": ["-y", "open-websearch-mcp"]
        }
      }
    }
  },

  "postCreateCommand": "npm install -g @anthropic-ai/claude-code 2>/dev/null || true"
}
