# Ignoere everything
*

# Unignore gitignore
!.gitignore

# Exceptions, the configs I actually want to store

# Whitelist
# Need to add both the root folder and the recursive wildcard
!init.sh
!fedora_atomic_setup.sh
!brave/
!brave/**
!scripts/
!scripts/**
!zsh/
!zsh/**
zsh/.zcompdump*
zsh/zcompdump*
zsh/.zsh_history
!README.md
!alacritty/
!alacritty/**
!claude/
!claude/**
!htop/
!htop/**
!opencode/
!opencode/**
!toolbox/
!toolbox/**
!tmux/
!tmux/**

# Assuring these kinds of files/folders do not get commited event if they are inside the whitelisted folders
**/.DS_Store
**/node_modules/
**/target/
**/*.log
**/__pycache__/
**/session/
**/cookies/
